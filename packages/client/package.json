{
  "name": "@1c-odata/client",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./filter": {
      "types": "./dist/filter.d.ts",
      "default": "./dist/filter.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.21.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "prepare": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude \"test/integration/**\"",
    "test:integration:offline": "echo 'no offline integration in client' && exit 0",
    "test:integration:live": "vitest run test/integration/live",
    "test:integration:write": "vitest run test/integration/write",
    "test:e2e": "echo no e2e in client && exit 0",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "package:lint": "publint && attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm"
  },
  "devDependencies": {
    "msw": "^2.14.3",
    "undici": "^6.25.0"
  }
}
