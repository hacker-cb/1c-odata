//#region src/hooks/console.d.ts
interface ConsoleHookOptions {
  /** Include body (truncated) in output. Default: false. */
  logBodies?: boolean;
  /** Truncate bodies to this many characters. Default: 2000. */
  maxBodyChars?: number;
