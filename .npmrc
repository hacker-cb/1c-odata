# Required so pnpm runs lifecycle scripts (preinstall, prepare, postinstall,
# etc.) for workspace packages during `pnpm install`. Without this, the
# `prepare: tsdown` hooks in @1c-odata/client and @1c-odata/cli would not
# fire, and the workspace bin symlink for `1c-odata` would not be created
# on a fresh install (target dist/cli.js missing → ENOENT → bin skipped).
#
# Scope: only first-party workspace packages run their hooks. Third-party
# deps (e.g. esbuild, msw, simple-git-hooks) still require explicit opt-in
# via `pnpm approve-builds` (separate `onlyBuiltDependencies` mechanism).
enable-pre-post-scripts=true
